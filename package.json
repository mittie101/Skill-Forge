{
  "name": "skillforge",
  "version": "1.0.0",
  "description": "AI skill file generator, builder, and installer",
  "author": "Antony Morrison <antony@walkingfishsoftware.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "rebuild": "electron-builder install-app-deps",
    "rebuild-force": "electron-rebuild -f -w better-sqlite3",
    "test": "jest --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.walkingfishsoftware.skillforge",
    "productName": "SkillForge",
    "copyright": "Copyright © 2025 Antony Morrison / Walking Fish Software",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "main/**/*",
      "ipc/**/*",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/.bin/**/*",
      "!**/*.map",
      "!**/tests/**",
      "build/**/*",
      "!dist/**",
      "!scripts/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SkillForge",
      "menuCategory": "SkillForge",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "SkillForge-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "SkillForge-Portable-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "mittie101",
      "repo": "Skill-Forge"
    }
  }
}
